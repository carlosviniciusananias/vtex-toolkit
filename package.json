{
  "name": "vtex-toolkit",
  "version": "1.0.3",
  "description": "Regras inteligentes para Cursor no ecossistema VTEX",
  "type": "module",
  "bin": {
    "vtex-toolkit": "bin/init.js"
  },
  "scripts": {
    "build": "node bin/sync-templates.js",
    "format": "prettier --write \"**/*.{md,mdc,json,jsonc,js,ts,tsx,css}\"",
    "format:check": "prettier --check \"**/*.{md,mdc,json,jsonc,js,ts,tsx,css}\""
  },
  "keywords": [
    "vtex",
    "cursor",
    "rules",
    "storefront",
    "faststore"
  ],
  "author": "Carlos Vinicius Ananias",
  "license": "MIT",
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "prettier": "^3.0.0",
    "semantic-release": "^25.0.3"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "fs-extra": "^11.3.4",
    "inquirer": "^9.3.8",
    "ora": "^5.4.1"
  },
  "directories": {
    "doc": "docs",
    "example": "examples"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carlosviniciusananias/vtex-toolkit.git"
  },
  "bugs": {
    "url": "https://github.com/carlosviniciusananias/vtex-toolkit/issues"
  },
  "homepage": "https://github.com/carlosviniciusananias/vtex-toolkit#readme"
}
