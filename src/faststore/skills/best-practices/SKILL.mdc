## 8. Performance e Core Web Vitals {#performance}

### Lazy Loading de Imagens

```typescript
// ✅ CORRETO - Next.js Image com lazy loading
import Image from "next/image"

const ProductImage = ({ src, alt }: Props) => {
  return (
    <Image
      src={src}
      alt={alt}
      width={300}
      height={300}
      loading="lazy"
      quality={80}
    />
  )
}
```

### Code Splitting com Dynamic Import

```typescript
// ✅ CORRETO - Carregar componentes pesados dinamicamente
import dynamic from "next/dynamic"

const HeavyComponent = dynamic(
  () => import("./components/HeavyComponent"),
  {
    loading: () => <div>Loading...</div>,
    ssr: false, // Desabilitar SSR se necessário
  }
)

const Page = () => {
  return (
    <div>
      <h1>My Page</h1>
      <HeavyComponent />
    </div>
  )
}
```

### Memoização

```typescript
// ✅ CORRETO - useMemo e useCallback
import { useMemo, useCallback } from "react"

const ProductList = ({ products }: Props) => {
  // Memoizar cálculos pesados
  const sortedProducts = useMemo(() => {
    return products.sort((a, b) => b.price - a.price)
  }, [products])
  
  // Memoizar callbacks
  const handleProductClick = useCallback((productId: string) => {
    sendAnalyticsEvent({
      name: "select_item",
      params: { item_id: productId }
    })
  }, [])
  
  return (
    <ul>
      {sortedProducts.map(product => (
        <li key={product.id} onClick={() => handleProductClick(product.id)}>
          {product.name}
        </li>
      ))}
    </ul>
  )
}
```

