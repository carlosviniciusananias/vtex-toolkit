## 7. Analytics e Tracking {#analytics}

### Eventos de Analytics

```typescript
// ✅ CORRETO - Usando FastStore Analytics
import { sendAnalyticsEvent, useAnalyticsEvent } from "@faststore/sdk"

// 1. Analytics Handler (ouvir todos os eventos)
export const AnalyticsHandler = () => {
  useAnalyticsEvent((event) => {
    console.log("Analytics Event:", event)
    
    // Enviar para Google Analytics, Meta Pixel, etc.
  })

  return null
}

// 2. Enviar eventos customizados
const CustomNewsletter = () => {
  const handleSubmit = async (email: string) => {
    // Evento de início
    sendAnalyticsEvent({
      name: "Submit Newsletter",
      params: {
        form_location: "custom_newsletter_section",
        user_agent: navigator.userAgent,
      },
    })
    
    try {
      await subscribeUser({ email })
      
      // Evento de sucesso
      sendAnalyticsEvent({
        name: "Submit newsletter success",
        params: {
          campaign: "newsletter_signup",
          source: "organic"
        },
      })
    } catch (error) {
      // Evento de erro
      sendAnalyticsEvent({
        name: "Submit newsletter error",
        params: {
          error_message: error.message
        },
      })
    }
  }
  
  return <form onSubmit={handleSubmit}>...</form>
}
```

### Eventos Padrão do E-commerce

```typescript
// ✅ CORRETO - Eventos padrão do FastStore
import { sendAnalyticsEvent } from "@faststore/sdk"

// View Item
sendAnalyticsEvent({
  name: "view_item",
  params: {
    items: [{
      item_id: product.id,
      item_name: product.name,
      price: product.offers.lowPrice,
      item_brand: product.brand.name,
    }]
  }
})

// Add to Cart
sendAnalyticsEvent({
  name: "add_to_cart",
  params: {
    currency: "USD",
    value: item.price,
    items: [{
      item_id: item.id,
      item_name: item.name,
      quantity: item.quantity,
    }]
  }
})

// Begin Checkout
sendAnalyticsEvent({
  name: "begin_checkout",
  params: {
    currency: "USD",
    value: cart.totalPrice,
    items: cart.items,
  }
})
```

