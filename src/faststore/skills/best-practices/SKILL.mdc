## 🎯 Exemplo Completo: Custom Product Section

```typescript
// src/components/sections/CustomProductDetails/CustomProductDetails.tsx
import { usePDP } from "@faststore/core"
import { Button, Icon } from "@faststore/ui"
import { sendAnalyticsEvent } from "@faststore/sdk"
import { useMemo } from "react"
import { priceFormatter } from "../../../utils/priceFormatter"

import styles from "./section.module.scss"

export interface CustomProductDetailsProps {
  /**
   * Show installment information
   */
  showInstallments?: boolean
  /**
   * Installments color variant
   */
  installmentsVariant?: "primary" | "secondary"
}

function CustomProductDetails({
  showInstallments = true,
  installmentsVariant = "primary"
}: CustomProductDetailsProps) {
  const context = usePDP()
  const product = context?.data?.product

  const bestInstallment = useMemo(() => {
    if (!product?.availableInstallments?.length) return null
    
    return product.availableInstallments.find(
      (inst) => inst.installmentInterest === 0
    )
  }, [product?.availableInstallments])

  const handleAddToCart = () => {
    sendAnalyticsEvent({
      name: "add_to_cart",
      params: {
        currency: "USD",
        value: product?.offers?.lowPrice,
        items: [{
          item_id: product?.id,
          item_name: product?.name,
        }]
      }
    })
  }

  if (!product) return null

  return (
    <section className={styles.section}>
      <h1 className={styles.title}>{product.name}</h1>
      
      <div className={styles.priceContainer}>
        <span className={styles.price}>
          {priceFormatter(product.offers.lowPrice)}
        </span>
        
        {showInstallments && bestInstallment && (
          <div className={`${styles.installments} ${styles[`installments--${installmentsVariant}`]}`}>
            <Icon name="CreditCard" width={20} height={20} />
            <span>
              {bestInstallment.installmentNumber}x of{" "}
              {priceFormatter(bestInstallment.installmentValue)}{" "}
              interest-free
            </span>
          </div>
        )}
      </div>

      <Button
        variant="primary"
        onClick={handleAddToCart}
        className={styles.buyButton}
      >
        Add to Cart
      </Button>
    </section>
  )
}

export default CustomProductDetails
```

