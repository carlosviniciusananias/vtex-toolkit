## 4. Hooks do FastStore {#hooks}

### Hooks Principais

```typescript
// ✅ CORRETO - Usando hooks do FastStore Core

// 1. usePDP - Dados da página de produto
import { usePDP } from "@faststore/core"

const ProductDetails = () => {
  const context = usePDP()
  const product = context?.data?.product
  
  console.log("Product:", product)
  console.log("Available Installments:", product?.availableInstallments)
  
  return <div>{product?.name}</div>
}

// 2. useSession - Dados da sessão do usuário
import { useSession } from "@faststore/sdk"

const UserInfo = () => {
  const { session } = useSession()
  
  console.log("Channel:", session?.channel)
  console.log("Country:", session?.country)
  console.log("Locale:", session?.locale)
  
  return <div>User: {session?.person?.email}</div>
}

// 3. useCart - Carrinho de compras
import { useCart } from "@faststore/sdk"

const CartInfo = () => {
  const { items, totalItems, totalPrice } = useCart()
  
  return (
    <div>
      <p>Items: {totalItems}</p>
      <p>Total: ${totalPrice}</p>
    </div>
  )
}

// 4. useBuyButton - Adicionar ao carrinho
import { useBuyButton } from "@faststore/sdk"

const AddToCartButton = ({ productId, seller }: Props) => {
  const buyButtonProps = useBuyButton({
    id: productId,
    seller: seller,
    price: 99.99,
    listPrice: 129.99,
    quantity: 1,
  })
  
  return <button {...buyButtonProps}>Add to Cart</button>
}

// 5. useUI - Toast notifications e UI state
import { useUI } from "@faststore/ui"

const NotificationExample = () => {
  const { pushToast } = useUI()
  
  const showSuccess = () => {
    pushToast({
      title: "Success!",
      message: "Item added to cart",
      status: "INFO",
    })
  }
  
  return <button onClick={showSuccess}>Show Toast</button>
}

// 6. useNewsletter - Newsletter subscription
import { useNewsletter_unstable as useNewsletter } from "@faststore/core/experimental"

const NewsletterForm = () => {
  const { subscribeUser, loading } = useNewsletter()
  
  const handleSubmit = async (email: string) => {
    await subscribeUser({
      data: { email }
    })
  }
  
  return <form>...</form>
}
```

