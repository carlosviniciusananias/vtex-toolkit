## 6. GraphQL e Fragments {#graphql}

### Fragments

```graphql
# ✅ CORRETO - src/fragments/ProductFragment.graphql
fragment ProductFragment on StoreProduct {
  id: productID
  slug
  sku
  brand {
    brandName
    name
  }
  name
  gtin
  description
  
  isVariantOf {
    productGroupID
    name
  }
  
  image {
    url
    alternateName
  }
  
  offers {
    lowPrice
    offers {
      availability
      price
      listPrice
      seller {
        identifier
      }
    }
  }
  
  # Campos adicionais customizados
  availableInstallments {
    installmentNumber
    installmentValue
    installmentInterest
    installmentPaymentSystemName
  }
}
```

### Queries

```graphql
# ✅ CORRETO - src/graphql/queries.graphql
query ProductDetailsQuery($slug: String!) {
  product(locator: [{ key: "slug", value: $slug }]) {
    ...ProductFragment
  }
}

query SearchQuery($first: Int!, $after: String, $term: String!) {
  search(
    first: $first
    after: $after
    sort: score_desc
    term: $term
  ) {
    products {
      pageInfo {
        totalCount
      }
      edges {
        node {
          ...ProductFragment
        }
      }
    }
  }
}
```

