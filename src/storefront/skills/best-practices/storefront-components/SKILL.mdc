## 8. Performance e Otimizações {#performance}

### Lazy Loading de Imagens

```typescript
// CORRETO - Lazy loading com intersection observer
import { useLazyLoadImages } from 'vtex.render-runtime'

const ProductImage: React.FC<{ src: string }> = ({ src }) => {
  const { lazyLoad } = useLazyLoadImages()
  
  return (
    <img 
      src={src}
      loading="lazy"
      data-lazy={lazyLoad}
    />
  )
}
```

### canUseDOM para SSR

```typescript
// CORRETO - Verificar ambiente cliente
import { canUseDOM } from 'vtex.render-runtime'

const CustomComponent: React.FC = () => {
  useEffect(() => {
    if (!canUseDOM) return
    
    // Código que só roda no cliente
    window.addEventListener('scroll', handleScroll)
    
    return () => {
      window.removeEventListener('scroll', handleScroll)
    }
  }, [])
  
  return <div>...</div>
}
```

### Memoização

```typescript
// CORRETO - useMemo para cálculos pesados
import { useMemo } from 'react'

const ProductList: React.FC<{ products: Product[] }> = ({ products }) => {
  const sortedProducts = useMemo(() => {
    return products.sort((a, b) => b.price - a.price)
  }, [products])
  
  return (
    <ul>
      {sortedProducts.map(product => (
        <li key={product.id}>{product.name}</li>
      ))}
    </ul>
  )
}
```

