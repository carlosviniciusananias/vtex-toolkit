## 5. Componentes React {#componentes-react}

### Estrutura de Componente

```typescript
// CORRETO - react/RecommendationShelf.tsx
import React from 'react'
import { defineMessages } from 'react-intl'

import { RecommendationShelfErrorBoundary } from './components/RecommendationShelfErrorBoundary'
import { RecommendationShelfContainer } from './components/RecommendationShelfContainer'

defineMessages({
  // ... messages
})

type Props = {
  campaignVrn: string
  title?: string
  displayTitle: boolean
  itemsContext: ItemContextType[]
}

const RecommendationShelf: StorefrontFunctionComponent<Props> = ({
  campaignVrn,
  title,
  displayTitle,
  itemsContext,
}) => {
  // Early return para validações
  if (!campaignVrn) return null

  return (
    <RecommendationShelfErrorBoundary>
      <RecommendationShelfContainer
        campaignVrn={campaignVrn}
        title={title}
        displayTitle={displayTitle}
        itemsContext={itemsContext}
      />
    </RecommendationShelfErrorBoundary>
  )
}

RecommendationShelf.schema = {
  // ... schema
}

export default RecommendationShelf
```

### Hooks Customizados

```typescript
// CORRETO - react/hooks/useRecommendations.tsx
import { useEffect, useState } from 'react'
import { canUseDOM, useRuntime } from 'vtex.render-runtime'

type RecommendationInput = {
  campaignVrn: string
  products: string[]
  userId?: string | null
}

function useRecommendations(args: RecommendationInput) {
  const runtime = useRuntime()
  const { account } = runtime

  const [data, setData] = useState<Response | null>(null)
  const [error, setError] = useState<Error | null>(null)
  const [loading, setLoading] = useState<boolean>(false)

  useEffect(() => {
    if (!canUseDOM) return

    setLoading(true)
    setError(null)

    fetch(`/api/recommend-bff/v2/recommendations?...`, {
      method: 'GET',
      headers: {
        'Content-Type': 'application/json',
      },
    })
      .then(async (response) => {
        if (!response.ok) {
          throw new Error(`HTTP error! status: ${response.status}`)
        }
        const result = await response.json()
        setData(result)
      })
      .catch((err) => {
        setError(err)
        setData(null)
      })
      .finally(() => {
        setLoading(false)
      })
  }, [account, args.campaignVrn, args.products])

  return {
    error,
    data,
    loading,
  }
}

export default useRecommendations
```

### Error Boundaries

```typescript
// CORRETO - react/components/RecommendationShelfErrorBoundary.tsx
import React, { Component, ErrorInfo, ReactNode } from 'react'

interface Props {
  children: ReactNode
}

interface State {
  hasError: boolean
  error?: Error
}

export class RecommendationShelfErrorBoundary extends Component<Props, State> {
  constructor(props: Props) {
    super(props)
    this.state = { hasError: false }
  }

  static getDerivedStateFromError(error: Error): State {
    return {
      hasError: true,
      error,
    }
  }

  componentDidCatch(error: Error, errorInfo: ErrorInfo) {
    console.error('RecommendationShelf Error:', error, errorInfo)
  }

  render() {
    if (this.state.hasError) {
      return null // Ou um fallback UI
    }

    return this.props.children
  }
}
```

