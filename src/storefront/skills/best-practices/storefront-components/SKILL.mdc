## 4. CSS Handles {#css-handles}

### Definição e Uso

```typescript
// CORRETO - Handles bem definidos
import { useCssHandles } from 'vtex.css-handles'

const CSS_HANDLES = [
  'container',
  'header',
  'title',
  'productList',
  'productItem',
  'productImage',
  'productName',
  'productPrice'
] as const

const CustomShelf: React.FC = () => {
  const handles = useCssHandles(CSS_HANDLES)
  
  return (
    <div className={handles.container}>
      <header className={handles.header}>
        <h2 className={handles.title}>Featured Products</h2>
      </header>
      <ul className={handles.productList}>
        {products.map(product => (
          <li key={product.id} className={handles.productItem}>
            <img className={handles.productImage} src={product.image} />
            <span className={handles.productName}>{product.name}</span>
          </li>
        ))}
      </ul>
    </div>
  )
}
```

