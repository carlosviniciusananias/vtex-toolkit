## 3. Destructuring do Context {#destructuring}

### ⚡ Regra de Ouro: Acesso Direto (Mais Eficiente)

Sempre destruturar o Context de forma direta e profunda, evitando múltiplas declarações intermediárias.

```typescript
// INCORRETO - Múltiplas extrações (menos eficiente)
export async function getClientById(ctx: Context, next: () => Promise<void>) {
  const { id } = ctx.vtex.route.params
  const { account, locale } = ctx.vtex
  
  const client = await ctx.clients.masterdata.getDocument({
    dataEntity: 'CL',
    id,
    fields: ['email', 'firstName', 'lastName']
  })
  
  // ...
}

// CORRETO - Destructuring direto e profundo (Express Best Practice)
export async function getClientById(ctx: Context, next: () => Promise<void>) {
  const {
    vtex: { 
      account, 
      locale, 
      route: { params: { id } } 
    },
    clients: { masterdata }
  } = ctx
  
  const client = await masterdata.getDocument({
    dataEntity: 'CL',
    id,
    fields: ['email', 'firstName', 'lastName']
  })
  
  // ...
}
```

### Por quê Destructuring Direto?

| Aspecto | Múltiplas Extrações | Destructuring Direto |
|---------|---------------------|---------------------|
| **Linhas de código** | 3-5 linhas | 1 linha |
| **Performance** | Múltiplos acessos | Acesso único |
| **Legibilidade** | Variáveis espalhadas | Tudo declarado junto |
| **Manutenção** | Dificulta refatoração | Fácil identificar dependências |

### Exemplos Práticos

```typescript
// CORRETO - POST /clients
export async function createClient(ctx: Context, next: () => Promise<void>) {
  const {
    vtex: { account },
    clients: { masterdata },
    req
  } = ctx
  
  const data = await json(req)
  
  // Validação
  if (!data.email || !data.firstName || !data.lastName) {
    ctx.status = 400
    ctx.body = {
      error: 'Missing required fields',
      code: 'VALIDATION_ERROR',
      details: { required: ['email', 'firstName', 'lastName'] }
    }
    return
  }
  
  const created = await masterdata.createOrUpdateEntireDocument({
    dataEntity: 'CL',
    fields: {
      email: data.email,
      firstName: data.firstName,
      lastName: data.lastName,
      document: data.document,
      phone: data.phone
    }
  })
  
  ctx.status = 201
  ctx.body = {
    id: created.Id,
    message: 'Client created successfully'
  }
  
  await next()
}

// CORRETO - GET /clients/:clientId/orders/:orderId
export async function getClientOrder(ctx: Context, next: () => Promise<void>) {
  const {
    vtex: { 
      account,
      route: { params: { clientId, orderId } } 
    },
    clients: { masterdata, oms }
  } = ctx
  
  try {
    // Buscar cliente e pedido em paralelo
    const [client, order] = await Promise.all([
      masterdata.getDocument({
        dataEntity: 'CL',
        id: clientId,
        fields: ['email', 'firstName']
      }),
      oms.order(orderId)
    ])
    
    if (!client) {
      ctx.status = 404
      ctx.body = { error: 'Client not found', code: 'CLIENT_NOT_FOUND' }
      return
    }
    
    if (!order || order.clientProfileData.email !== client.email) {
      ctx.status = 404
      ctx.body = { error: 'Order not found', code: 'ORDER_NOT_FOUND' }
      return
    }
    
    ctx.status = 200
    ctx.body = {
      client,
      order
    }
  } catch (error) {
    console.error('Error fetching client order:', error)
    ctx.status = 500
    ctx.body = {
      error: 'Internal server error',
      code: 'INTERNAL_ERROR',
      message: error instanceof Error ? error.message : 'Unknown error'
    }
  }
  
  await next()
}

// CORRETO - PATCH /clients/:id (atualização parcial)
export async function patchClient(ctx: Context, next: () => Promise<void>) {
  const {
    vtex: { route: { params: { id } } },
    clients: { masterdata },
    req
  } = ctx
  
  try {
    const data = await json(req)
    
    // PATCH aceita campos parciais (diferente de PUT)
    if (Object.keys(data).length === 0) {
      ctx.status = 400
      ctx.body = {
        error: 'No fields to update',
        code: 'EMPTY_BODY'
      }
      return
    }
    
    await masterdata.updatePartialDocument({
      dataEntity: 'CL',
      id,
      fields: data
    })
    
    ctx.status = 200
    ctx.body = {
      id,
      message: 'Client updated successfully'
    }
  } catch (error) {
    console.error('Error updating client:', error)
    ctx.status = 500
    ctx.body = {
      error: 'Failed to update client',
      code: 'UPDATE_ERROR',
      message: error instanceof Error ? error.message : 'Unknown error'
    }
  }
  
  await next()
}
```

