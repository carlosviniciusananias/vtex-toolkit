## 5. Tipos TypeScript {#tipos}

### Interfaces de Domínio

```typescript
// CORRETO - node/types/clients.d.ts
export interface Client {
  id: string
  email: string
  firstName: string
  lastName: string
  document: string
  phone?: string
  createdAt: string
  updatedAt: string
}

export interface CreateClientInput {
  email: string
  firstName: string
  lastName: string
  document: string
