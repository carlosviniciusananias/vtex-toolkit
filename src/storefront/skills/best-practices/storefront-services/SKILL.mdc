## Exemplos Práticos Completos

### CRUD Completo de Clientes

**1. service.json:**
```json
{
  "routes": {
    "listClients": {
      "path": "/_v/clients",
      "public": false
    },
    "getClient": {
      "path": "/_v/clients/:id",
      "public": false
    },
    "createClient": {
      "path": "/_v/clients",
      "public": false
    },
    "updateClient": {
      "path": "/_v/clients/:id",
      "public": false
    },
    "deleteClient": {
      "path": "/_v/clients/:id",
      "public": false
    }
  }
}
```

**2. node/middlewares/clients/createClient.ts:**
```typescript
import { json } from 'co-body'
import type { Context } from '@vtex/api'
import type { CreateClientInput } from '../../types/clients'

export async function createClient(ctx: Context, next: () => Promise<void>) {
  try {
    const data: CreateClientInput = await json(ctx.req)
    
    // Validação
    if (!data.email || !data.firstName || !data.lastName) {
      ctx.status = 400
      ctx.body = {
        error: 'Missing required fields',
        code: 'VALIDATION_ERROR',
        details: { required: ['email', 'firstName', 'lastName'] }
      }
      return
    }
    
    // Criar usando cliente nativo
    const created = await ctx.clients.masterdata.createOrUpdateEntireDocument({
      dataEntity: 'CL',
      fields: {
        email: data.email,
        firstName: data.firstName,
        lastName: data.lastName,
        document: data.document,
        phone: data.phone
      }
    })
    
    ctx.status = 201
    ctx.body = {
      id: created.Id,
      message: 'Client created successfully'
    }
  } catch (error) {
    console.error('Error creating client:', error)
    
    ctx.status = 500
    ctx.body = {
      error: 'Failed to create client',
      code: 'CREATE_ERROR',
      message: error instanceof Error ? error.message : 'Unknown error'
    }
  }
  
  await next()
}
```

**3. node/index.ts:**
```typescript
import { Service } from '@vtex/api'
import { Clients } from './clients'
import { method } from '@vtex/api'

import { createClient } from './middlewares/clients/createClient'
import { getClientById } from './middlewares/clients/getClientById'
import { updateClient } from './middlewares/clients/updateClient'
import { deleteClient } from './middlewares/clients/deleteClient'
import { listClients } from './middlewares/clients/listClients'

export default new Service({
  clients: {
    implementation: Clients,
    options: {
      default: {
        retries: 2,
        timeout: 10000
      }
    }
  },
  routes: {
    listClients: method({
      GET: [listClients]
    }),
    getClient: method({
      GET: [getClientById]
    }),
    createClient: method({
      POST: [createClient]
    }),
    updateClient: method({
      PUT: [updateClient]
    }),
    deleteClient: method({
      DELETE: [deleteClient]
    })
  }
})
```

