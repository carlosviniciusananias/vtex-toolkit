## 1. Nomenclatura de Funções e Middlewares {#nomenclatura}

### Middlewares

**Padrão:** `verbo + Entidade + Ação`

```typescript
// CORRETO - Verbos imperativos, nomes claros
export async function getClientById(ctx: Context, next: () => Promise<void>) {}
export async function createClient(ctx: Context, next: () => Promise<void>) {}
export async function updateClientAddress(ctx: Context, next: () => Promise<void>) {}
export async function deleteClient(ctx: Context, next: () => Promise<void>) {}
export async function listClients(ctx: Context, next: () => Promise<void>) {}

// INCORRETO - Nomes vagos ou mal formatados
export async function getCL(ctx: Context, next: () => Promise<void>) {} // Sigla não clara
export async function middleware1(ctx: Context, next: () => Promise<void>) {} // Genérico
export async function ClientGet(ctx: Context, next: () => Promise<void>) {} // PascalCase incorreto
export async function client_update(ctx: Context, next: () => Promise<void>) {} // snake_case
```

### Helpers e Utilitários

**Padrão:** `verbo + Substantivo` ou `get + Tipo`

```typescript
// CORRETO
export const validateEmail = (email: string): boolean => {}
export const formatAddress = (address: Address): string => {}
export const parseOrderData = (data: unknown): Order => {}
export const getAppSettings = async (ctx: Context): Promise<AppSettings> => {}

// INCORRETO
export const validator = (email: string): boolean => {} // Muito genérico
export const doFormat = (address: Address): string => {} // "do" desnecessário
export const settings = async (ctx: Context): Promise<AppSettings> => {} // Não é verbo
```

### Clients Customizados (quando necessário)

**Padrão:** `NomeAPI + Client` (PascalCase)

```typescript
// CORRETO
export class ShippingAPIClient extends JanusClient {}
export class PaymentGatewayClient extends ExternalClient {}
export class NotificationServiceClient extends JanusClient {}

// INCORRETO
export class shippingClient extends JanusClient {} // camelCase
export class Client extends JanusClient {} // Muito genérico
export class API extends JanusClient {} // Não descreve função
```

